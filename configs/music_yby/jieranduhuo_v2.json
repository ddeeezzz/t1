{
  "mode": {
    "script_generator": "multi_role_llm_v2"
  },
  "paths": {
    "runs_dir": "/root/data/runs",
    "default_audio_path": "resources/jieranduhuo.mp3"
  },
  "ffmpeg": {
    "ffmpeg_bin": "ffmpeg",
    "ffprobe_bin": "ffprobe",
    "video_codec": "libx264",
    "audio_codec": "aac",
    "fps": 24,
    "video_preset": "veryfast",
    "video_crf": 24,
    "render_batch_size": 1,
    "video_accel_mode": "cpu_only"
  },
  "logging": {
    "level": "INFO"
  },
  "mock": {
    "beat_interval_seconds": 0.5
  },
  "render": {
    "video_width": 768,
    "video_height": 432
  },
  "module_b": {
    "script_workers": 1,
    "unit_retry_times": 1,
    "llm": {
      "provider": "siliconflow",
      "base_url": "https://api.siliconflow.cn/v1",
      "model": "deepseek-ai/DeepSeek-V3.2",
      "api_key_file": ".secrets/siliconflow_api_key.txt",
      "timeout_seconds": 60.0,
      "request_retry_times": 2,
      "json_retry_times": 2,
      "temperature": 0.3,
      "top_p": 0.9,
      "max_tokens": 0,
      "use_response_format_json_object": true,
      "scene_desc_max_chars": 0,
      "keyframe_prompt_max_chars": 0,
      "video_prompt_max_chars": 0,
      "prompt_template_file": "configs/prompts/module_b_prompt.v1.md"
    }
  },
  "module_c": {
    "render_workers": 3,
    "unit_retry_times": 1
  },
  "module_d": {
    "segment_workers": 1,
    "unit_retry_times": 1,
    "render_backend": "comfyui"
  },
  "cross_module": {
    "global_render_limit": 3,
    "scheduler_tick_ms": 50
  },
  "monitoring": {
    "max_wait_after_terminal_minutes": 20.0
  },
  "bypy_upload": {
    "enabled": true,
    "bypy_bin": "/root/data/t1/.venv/bin/bypy",
    "remote_runs_dir": "/runs",
    "retry_times": 2,
    "timeout_seconds": 1800.0,
    "config_dir": "~/.bypy",
    "require_auth_file": true
  },
  "module_a": {
    "mode": "real_auto",
    "lyric_beat_snap_threshold_ms": 200,
    "instrumental_labels": [
      "intro",
      "outro",
      "inst"
    ],
    "fallback_enabled": true,
    "device": "auto",
    "funasr_language": "auto",
    "funasr_model": "FunAudioLLM/Fun-ASR-Nano-2512",
    "vad_model": "iic/speech_fsmn_vad_zh-cn-16k-common-pytorch",
    "demucs_model": "htdemucs",
    "comma_pause_seconds": 0.45,
    "long_pause_seconds": 0.8,
    "merge_gap_seconds": 0.25,
    "max_visual_unit_seconds": 6.0,
    "content_role_tiny_merge_bars": 0.9,
    "long_lyric_resplit_max_bars": 2.0,
    "long_other_split_min_bars": 1.0,
    "major_split_step_bars": 2.5,
    "visual_lead_seconds": 0.06,
    "implementation": "v2"
  }
}
